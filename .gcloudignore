# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore.

# Ignore git directory
.git
.github
.gitignore

# Ignore development files
*.md
# The Steve Build Guide is a RUNTIME prompt (loaded by backend/services/builder.py);
# it MUST be uploaded so it ships in the image.
!backend/services/builder_guide.md
# Landing legal pages (vite ?raw imports — required for cpoint-landing image build)
!landing/src/content/legal/
!landing/src/content/legal/**
*.sh
# Production Cloud Build needs these (cloudbuild-production.yaml steps 3–4)
!scripts/wire_prod_cloud_run_secrets.sh
!scripts/smoke_prod.sh
*.sql
*.sample
*.example

# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class
.Python
*.so

# Ignore virtual environments
venv/
env/
.env
.env.*

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo

# Client source is needed for Dockerfile build (builds client in image)
# Ignore generated/install artifacts; Dockerfile rebuilds client from source.
client/node_modules/
client/dist/
client/.env*

# Landing: full source is uploaded for Dockerfile.landing (npm ci + vite build in image).
# Exclude only heavy or secret paths (align with .dockerignore).
landing/node_modules/
landing/dist/
landing/.env*

# Repo-root package installs (never upload)
node_modules/

# Ignore test and debug files
test_*.py
check_*.py
debug_*.py
fix_*.py
*_test.py
diagnose_*.py
verify_*.py
database_diagnostic.py

# Ignore migration and setup scripts
add_*.py
migrate_*.py
*_migration.py
apply_*.py
create_env_file.py
insert_test_token.py
init_community_db.py

# Ignore utility scripts
optimize_*.py
force_*.py
complete_revert.py
direct_migration.py
revert_chat_changes.py

# Ignore misc files
cookies.txt
*.pid
CLEANUP_INSTRUCTIONS.txt
START_HERE_AWS.txt
manual_install_commands.txt
