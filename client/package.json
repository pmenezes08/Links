{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync:staging": "npx cross-env CPOINT_CAPACITOR_PROFILE=staging npx cap sync",
    "cap:sync:prod": "npx cross-env CPOINT_CAPACITOR_PROFILE=production npx cap sync",
    "cap:copy:prod": "npx cross-env CPOINT_CAPACITOR_PROFILE=production npx cap copy",
    "postinstall": "npx patch-package || true; bash patches/fix-google-auth-ios.sh || true"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^8.0.2",
    "@capacitor-community/apple-sign-in": "^6.0.0",
    "@capacitor-community/in-app-review": "^6.0.0",
    "@capacitor-community/media": "^6.0.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/device": "^6.0.3",
    "@capacitor/dialog": "^6.0.3",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/network": "^6.0.4",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@capacitor/toast": "^6.0.4",
    "@capawesome/capacitor-badge": "^6.0.0",
    "@capgo/inappbrowser": "^6.15.0",
    "@capgo/native-purchases": "^6.0.42",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ebarooni/capacitor-calendar": "^6.7.2",
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@tanstack/react-query": "^5.62.7",
    "chart.js": "^4.4.7",
    "classnames": "^2.5.1",
    "gifuct-js": "^2.1.2",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.1.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.28.0",
    "react-virtuoso": "^4.18.7",
    "stay-liquid": "github:alistairheath/stay-liquid"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@eslint/js": "^9.33.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.0.2",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^4.1.5"
  }
}
