.git
.gitignore
node_modules
client/node_modules
client/dist
*.log
debug-*.log
__pycache__
*.pyc
.env
.env.*
# NOTE: no blanket `*.md` exclude. backend/services/builder_guide.md is a RUNTIME
# prompt that MUST ship, and `gcloud builds submit` does not reliably honour a `!`
# negation. The Dockerfile only COPYs backend/ + templates/ + static/, so root/docs
# markdown never reach the image anyway — `*.md` was only stripping the guide.
.cursor
.vscode
admin-web
# landing/ must be present for Dockerfile.landing; exclude heavy / generated paths only
landing/node_modules
landing/dist
