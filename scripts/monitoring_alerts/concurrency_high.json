{
  "displayName": "cpoint-app: Concurrent requests > 60 (5m)",
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Concurrent requests per instance > 60 for 5 minutes",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"cpoint-app\" AND metric.type=\"run.googleapis.com/container/max_request_concurrencies\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 60,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_MAX"
          }
        ]
      }
    }
  ],
  "enabled": true
}
