# Local environment files — real secrets must never be committed.
# (.env.example is the tracked placeholder template; copy it to .env.local
#  and fill real values there. Real secrets belong in Secret Manager /
#  Cloud Run env vars, never in the repo.)
.env
.env.*
!.env.example

# Deploy / CI / diagnostic logs (generated during scripts, never commit)
*-deploy.log
ci-job-*.log
gcm-diagnose.log
staging-smoke-*.log

# Understand Anything — keep graph, exclude scratch
.understand-anything/intermediate/
.understand-anything/tmp/
.understand-anything/diff-overlay.json
**/.understand-anything/intermediate/
**/.understand-anything/tmp/
